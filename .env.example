# OpenClaw Gateway (generado/actualizado por scripts/setup-openclawd.sh)
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_DISABLE_BONJOUR=1
OPENCLAW_TZ=UTC

# MiniMax — razonamiento / redacción del briefing (agente beacon-lab)
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_MODEL=minimax/MiniMax-M3

# Tavily — búsqueda web (web_search, tavily_search, tavily_extract)
TAVILY_API_KEY=your-tavily-api-key-here

# Agent API → OpenClawD (OPENCLAWD_API_KEY debe coincidir con OPENCLAW_GATEWAY_TOKEN)
OPENCLAWD_BASE_URL=http://openclawd:18789
OPENCLAWD_API_KEY=your-gateway-token-here

# Routing del agente Beacon Lab en OpenClaw
OPENCLAWD_MODEL=openclaw:beacon-lab
OPENCLAWD_AGENT_ID=beacon-lab

# Request timeout in seconds (briefings can take a while)
OPENCLAWD_TIMEOUT_SECONDS=180

# Puerto en el host para agent-api (contenedor sigue en :8000)
AGENT_API_PORT=8010
