# OpenClawD / OpenClaw Gateway
OPENCLAWD_BASE_URL=http://openclawd:18789
OPENCLAWD_API_KEY=your-gateway-token-here

# Optional: agent routing (OpenAI "model" field or x-openclaw-agent-id header)
OPENCLAWD_MODEL=openclaw:beacon-lab
OPENCLAWD_AGENT_ID=beacon-lab

# Request timeout in seconds (briefings can take a while)
OPENCLAWD_TIMEOUT_SECONDS=180

# Attach web_search tool definition for Tavily / Gateway search tooling
ENABLE_WEB_SEARCH_TOOL=true
